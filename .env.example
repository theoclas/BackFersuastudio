# ============================================================
#  FersuaStudio — Variables de Entorno (Plantilla de Producción)
#  Este archivo sirve de guía. EN PRODUCCIÓN, configura esto
#  directamente en el panel de Hostinger (Variables de Entorno).
# ============================================================

# ──────────────────────────────────────
#  Base de Datos MariaDB (Hostinger)
# ──────────────────────────────────────
# En Hostinger, deberás apuntar a la base de datos MySQL local si
# el backend se hospeda en el mismo servidor (localhost).
# De lo contrario usa la IP.
DATABASE_URL="mysql://USUARIO_DB:PASSWORD_DB@localhost:3306/NOMBRE_DB"

# ──────────────────────────────────────
#  Servidor NestJS
# ──────────────────────────────────────
PORT=3001
# IMPORTANTÍSIMO mantenerlo en 'production' en Hostinger
NODE_ENV=production

# ──────────────────────────────────────
#  Seguridad JWT
# ──────────────────────────────────────
# REQUISITO CRÍTICO: Generar un string criptográfico largo
# Puedes usar: openssl rand -base64 32
JWT_SECRET="reemplaza_con_un_secreto_criptografico_indescifrable_en_produccion"
# Expiración corta para mayor seguridad en producción (ej. 1d o 12h)
JWT_EXPIRES_IN=1d

# ──────────────────────────────────────
#  Registro público (opcional)
# ──────────────────────────────────────
# false = solo un ADMIN puede crear usuarios (panel /dashboard/admin/users)
PUBLIC_REGISTRATION_ENABLED=false
# Si true, la cuenta nace inactiva: un ADMIN debe activarla en "Gestionar usuarios"
REGISTRATION_DEFAULT_INACTIVE=false

# ──────────────────────────────────────
#  CORS y Frontend
# ──────────────────────────────────────
# Un origen o varios separados por coma (sin espacios extra si puedes).
# Incluye http://localhost:5173 si pruebas Vite en local contra este API en hosting.
# Ejemplo:
#   FRONTEND_URL="http://localhost:5173,https://fersuastudio.com,https://www.fersuastudio.com"
FRONTEND_URL="https://midominio.com"

# Archivos subidos (galería / portadas) se guardan en ./uploads/artists relativo al
# directorio de trabajo del proceso Node. En Hostinger, el disco debe persistir entre
# despliegues o usar almacenamiento externo (S3, etc.).

# ──────────────────────────────────────
#  Servicio SMTP de Notificaciones
# ──────────────────────────────────────
# Considerar usar SendGrid/AWS SES en vez de Gmail a largo plazo,
# pero Gmail con App Password funciona para empezar.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER="notificaciones@fersuastudio.com"
MAIL_PASS="tu_app_password_fuerte"
MAIL_FROM="FersuaStudio Booking <notificaciones@fersuastudio.com>"
